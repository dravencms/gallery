{
  "name": "dravencms/gallery",
  "type": "dravencms-package",
  "description": "Gallery module for dravencms",
  "keywords": [
    "dravencms",
    "gallery"
  ],
  "license": [
    "LGPL-3.0-only"
  ],
  "authors": [
    {
      "name": "Adam Schubert"
    }
  ],
  "require": {
    "dravencms/admin": "^2.3",
    "dravencms/tag": "^2.0",
    "dravencms/file": "^2.1"
  },
  "suggest": {
    "dravencms/structure": "Allows gallery components to be used in cms"
  },
  "require-dev": {
    "nette/tester": "@dev"
  },
  "autoload": {
    "psr-0": {
      "Dravencms\\": "src/"
    }
  },
  "extra": {
    "dravencms": {
      "configuration": "dravencms.config.neon"
    }
  }
}
